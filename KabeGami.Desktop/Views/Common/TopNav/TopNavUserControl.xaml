<UserControl x:Class="KabeGami.Desktop.Views.Common.TopNav.TopNavUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KabeGami.Desktop.Views.Common.TopNav"
             xmlns:test="clr-namespace:KabeGami.Desktop.Views.Test"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Menu>
        <TextBlock
            Text="{Binding X}">
        </TextBlock>
        <Button Command="{Binding Test}">Click</Button>
        <MenuItem Header="KabeGami">
            <MenuItem Header="SetGallery" Command="{Binding Test}"/>
        </MenuItem>
        <MenuItem Header="Gallery"/>
        <MenuItem Header="Image"/>
    </Menu>
</UserControl>
